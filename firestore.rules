
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isAdmin() {
      return hasRole('Admin');
    }

    function isManager() {
      return hasRole('Manager');
    }

    function isAdminOrManager() {
      return isAdmin() || isManager();
    }

    // --- COLLECTION RULES ---

    match /userProfiles/{userId} {
      // พนักงานทุกคนเห็นรายชื่อกันได้
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId);
      // เฉพาะเจ้าของโปรไฟล์ หรือ Admin/Manager ถึงจะแก้ได้
      allow update: if isOwner(userId) || isAdminOrManager();
      // เฉพาะ Admin เท่านั้นที่ลบพนักงานได้
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow get, list: if isSignedIn();
      // พนักงานทุกคนจัดการสินค้าได้ (ปรับตามความต้องการผู้ใช้ที่ต้องการความคล่องตัว)
      allow create, update, delete: if isSignedIn();
    }

    match /orders/{orderId} {
      // Admin/Manager เห็นหมด หรือ Cashier เห็นของตัวเอง
      allow get: if isAdminOrManager() || (resource != null && resource.data.cashierId == request.auth.uid);
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      // เฉพาะ Admin/Manager หรือเจ้าของรายการถึงจะแก้ได้
      allow update: if isAdminOrManager() || (resource != null && resource.data.cashierId == request.auth.uid);
      // เฉพาะ Admin เท่านั้นที่ลบประวัติการขายได้
      allow delete: if isAdmin();

      match /order_items/{orderItemId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isAdminOrManager();
      }
    }
  }
}
