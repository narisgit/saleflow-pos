/**
 * SaleFlow POS Security Rules
 *
 * Core Philosophy:
 * This ruleset implements a robust Role-Based Access Control (RBAC) system.
 * It allows all signed-in staff to manage inventory and sales, while restricting
 * sensitive administrative tasks (like deleting staff) to Managers and Admins.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role;
    }

    function hasRole(role) {
      return isSignedIn() && getUserRole() == role;
    }

    // defines high-level staff who can manage roles and deletion
    function isAdminOrManager() {
      return hasRole('Manager') || hasRole('Admin');
    }

    // --- COLLECTION RULES ---

    match /userProfiles/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); // Allow staff to see colleagues
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdminOrManager();
      allow delete: if isAdminOrManager();
    }

    match /products/{productId} {
      allow get, list: if isSignedIn();
      // Allow all signed-in staff to manage products for operational flexibility
      allow create, update, delete: if isSignedIn();
    }

    match /orders/{orderId} {
      allow get: if isAdminOrManager() || (resource != null && resource.data.cashierId == request.auth.uid);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.cashierId == request.auth.uid;
      allow update: if isAdminOrManager() || (resource != null && resource.data.cashierId == request.auth.uid);
      allow delete: if isAdminOrManager();

      match /order_items/{orderItemId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isAdminOrManager();
      }
    }
  }
}