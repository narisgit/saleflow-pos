
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isAdmin() {
      return hasRole('Admin');
    }

    function isManager() {
      return hasRole('Manager');
    }

    function isAdminOrManager() {
      return isAdmin() || isManager();
    }

    // --- COLLECTION RULES ---

    match /userProfiles/{userId} {
      // ทุกคนที่ล็อกอินสามารถอ่านชื่อพนักงานได้ (เพื่อแสดงในใบเสร็จ)
      allow read: if isSignedIn();
      // เฉพาะ Admin เท่านั้นที่สามารถจัดการรายชื่อและตำแหน่งพนักงานได้
      allow write: if isAdmin();
      // อนุญาตให้เจ้าของโปรไฟล์แก้ไขชื่อหรืออีเมลตัวเองได้ แต่ห้ามเปลี่ยน Role (ผ่านกฎระมัดระวัง)
      allow update: if isOwner(userId) && (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /products/{productId} {
      allow get, list: if isSignedIn();
      // เฉพาะ Admin หรือ Manager เท่านั้นที่จัดการสต็อกสินค้าได้
      allow create, update, delete: if isAdminOrManager();
    }

    match /orders/{orderId} {
      allow get: if isAdminOrManager() || (resource != null && resource.data.cashierId == request.auth.uid);
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      // ห้ามแก้ไขรายการสั่งซื้อที่จบไปแล้ว นอกจาก Admin/Manager
      allow update: if isAdminOrManager();
      // เฉพาะ Admin เท่านั้นที่ลบประวัติการขายได้
      allow delete: if isAdmin();

      match /order_items/{orderItemId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isAdminOrManager();
      }
    }
  }
}
