/**
 * SaleFlow POS Security Rules
 *
 * Core Philosophy:
 * This ruleset implements a robust Role-Based Access Control (RBAC) system combined with strict 
 * user-ownership models. It balances the need for staff (Managers/Admins) to oversee all 
 * operations with the requirement that Cashiers only manage their own transactional data.
 *
 * Data Structure:
 * - /userProfiles/{userId}: Root collection for user identity and role assignment. 
 *   The document ID matches the Firebase Auth UID.
 * - /products/{productId}: Root collection for the product catalog.
 * - /orders/{orderId}: Root collection for finalized transactions.
 * - /orders/{orderId}/order_items/{itemId}: Subcollection for line items within an order.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role;
    }

    function hasRole(role) {
      return isSignedIn() && getUserRole() == role;
    }

    // defines high-level staff who can manage inventory/profiles
    function isStaff() {
      return hasRole('Manager') || hasRole('Admin');
    }

    // --- COLLECTION RULES ---

    match /userProfiles/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); // Allow all staff to see names of colleagues
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isStaff();
      allow delete: if isStaff();
    }

    match /products/{productId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isStaff();
    }

    match /orders/{orderId} {
      allow get: if isStaff() || (resource != null && resource.data.cashierId == request.auth.uid);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.cashierId == request.auth.uid;
      allow update: if isStaff() || (resource != null && resource.data.cashierId == request.auth.uid);
      allow delete: if isStaff();

      match /order_items/{orderItemId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isStaff();
      }
    }
  }
}