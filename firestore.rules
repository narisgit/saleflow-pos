
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isAdmin() {
      return hasRole('Admin');
    }

    function isManager() {
      return hasRole('Manager');
    }

    function isAdminOrManager() {
      return isAdmin() || isManager();
    }

    // --- COLLECTION RULES ---

    match /userProfiles/{userId} {
      // ทุกคนที่ล็อกอินสามารถอ่านชื่อพนักงานได้
      allow read: if isSignedIn();
      // อนุญาตให้ Admin จัดการทุกคน
      allow write: if isAdmin();
      // **กฎฉุกเฉิน**: อนุญาตให้เจ้าของโปรไฟล์สร้างหรือแก้ไขโปรไฟล์ตัวเองได้ 
      // เพื่อป้องกันกรณีไม่มี Admin เหลือในระบบสำหรับการทดสอบ
      allow create, update: if isOwner(userId);
    }

    match /products/{productId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdminOrManager();
    }

    match /orders/{orderId} {
      allow get: if isAdminOrManager() || (resource != null && resource.data.cashierId == request.auth.uid);
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdminOrManager();
      allow delete: if isAdmin();

      match /order_items/{orderItemId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isAdminOrManager();
      }
    }
  }
}
